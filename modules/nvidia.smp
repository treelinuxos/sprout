#!/usr/bin/env micropython
"""
nvidia.smp — detect and install nvidia drivers.

this module detects the GPU vendor and installs the correct
nvidia drivers for the current kernel.
"""

import sprout

gpu = sprout.detect("gpu")

if gpu != "nvidia":
    sprout.info("no nvidia GPU detected, skipping")
    sys.exit(0)

sprout.info("nvidia GPU detected — installing drivers")
sprout.apply("nvidia-drivers")
sprout.info("driver installation complete")
